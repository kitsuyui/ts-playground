{
  "name": "@kitsuyui/mymath",
  "type": "module",
  "version": "0.0.0",
  "license": "MIT",
  "author": "Yui Kitsu <kitsuyui@kitsuyui.com>",
  "description": "A simple additional library for Math",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --no-clean --watch",
    "test": "vitest run",
    "validate": "validate-package-exports --check"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kitsuyui/ts-playground.git"
  },
  "exports": {
    ".": {
      "require": {
        "type": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "type": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./array": {
      "require": {
        "type": "./dist/array.d.cts",
        "default": "./dist/array.cjs"
      },
      "import": {
        "type": "./dist/array.d.ts",
        "default": "./dist/array.js"
      }
    },
    "./intervalMapper": {
      "require": {
        "type": "./dist/intervalMapper.d.cts",
        "default": "./dist/intervalMapper.cjs"
      },
      "import": {
        "type": "./dist/intervalMapper.d.ts",
        "default": "./dist/intervalMapper.js"
      }
    },
    "./log": {
      "require": {
        "type": "./dist/log.d.cts",
        "default": "./dist/log.cjs"
      },
      "import": {
        "type": "./dist/log.d.ts",
        "default": "./dist/log.js"
      }
    },
    "./polar": {
      "require": {
        "type": "./dist/polar.d.cts",
        "default": "./dist/polar.cjs"
      },
      "import": {
        "type": "./dist/polar.d.ts",
        "default": "./dist/polar.js"
      }
    },
    "./sigmoid": {
      "require": {
        "type": "./dist/sigmoid.d.cts",
        "default": "./dist/sigmoid.cjs"
      },
      "import": {
        "type": "./dist/sigmoid.d.ts",
        "default": "./dist/sigmoid.js"
      }
    },
    "./softmax": {
      "require": {
        "type": "./dist/softmax.d.cts",
        "default": "./dist/softmax.cjs"
      },
      "import": {
        "type": "./dist/softmax.d.ts",
        "default": "./dist/softmax.js"
      }
    },
    "./clamp": {
      "require": {
        "type": "./dist/clamp.d.cts",
        "default": "./dist/clamp.cjs"
      },
      "import": {
        "type": "./dist/clamp.d.ts",
        "default": "./dist/clamp.js"
      }
    }
  },
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "package.json"
  ],
  "devDependencies": {}
}
